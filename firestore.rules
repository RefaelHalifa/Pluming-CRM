rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: name (string), email (string), role (string: manager, secretary, worker)
    //
    // Collection: customers
    // Fields: name (string), email (string), phone (string), address (string), createdAt (timestamp)
    //
    // Collection: jobs
    // Fields: customerId (string), customerName (string), workerId (string), workerName (string), 
    //         date (timestamp), description (string), status (string), workerSummary (string), 
    //         isSuccess (bool), paymentStatus (string), amount (number), secretaryNotes (string)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdminEmail() {
      return isAuthenticated() && 
             'email' in request.auth.token && 
             request.auth.token.email.lower() == "rafaelhalifa@gmail.com";
    }

    function isManager() {
      return isAuthenticated() && (
        isAdminEmail() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager')
      );
    }

    function isSecretary() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'secretary';
    }

    function isWorker() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'worker';
    }

    // Rules for Users
    match /users/{userId} {
      // Allow unauthenticated get for custom login fallback
      // This is necessary to check passwords for users not in Firebase Auth
      allow get: if true;
      
      // Allow users to read their own profile
      allow read: if isAuthenticated() && request.auth.uid == userId;
      
      // Allow managers and secretaries to read all user profiles
      allow read: if isAdminEmail() || isManager() || isSecretary();
      
      // Allow managers to create/update any user, and users to create their own initial profile
      allow create: if isManager() || (isAuthenticated() && request.auth.uid == userId);
      allow update: if isManager() || (isAuthenticated() && request.auth.uid == userId);
      
      // Only managers can delete users (except themselves)
      allow delete: if isManager() && userId != request.auth.uid;
    }

    // Rules for Customers
    match /customers/{customerId} {
      allow read: if isAuthenticated();
      allow write: if isManager() || isSecretary();
    }

    // Rules for Jobs
    match /jobs/{jobId} {
      allow read: if isAuthenticated();
      allow create: if isManager() || isSecretary();
      allow update: if isManager() || isSecretary() || (isWorker() && request.auth.uid == resource.data.workerId);
      allow delete: if isManager() || isSecretary();
    }
  }
}
